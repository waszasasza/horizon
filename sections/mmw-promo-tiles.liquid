{%- comment -%}
  mmw-promo-tiles — dwa kafle cross-promo (Winnica / Hotel).
  Każdy kafel = blok: logo + nagłówek + przycisk, z własnymi kolorami (tło, tekst, przycisk).
  Domyślnie 2 kafle obok siebie; na mobile jeden pod drugim.
{%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} .mmw-promo { display:flex; justify-content:center; padding-block:50px; padding-inline: max(var(--page-margin, 40px), calc((100% - var(--mmw-article-width, 1240px)) / 2)); }
  #shopify-section-{{ section.id }} .mmw-promo__row { display:flex; gap:27px; align-items:stretch; justify-content:center; width:100%; }
  #shopify-section-{{ section.id }} .mmw-promo__tile { flex:1 1 0; min-width:0; min-height:580px; border-radius:8px; overflow:hidden; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:34px; padding:30px; text-align:center; }
  #shopify-section-{{ section.id }} .mmw-promo__logo { max-width:289px; max-height:90px; }
  #shopify-section-{{ section.id }} .mmw-promo__logo img, #shopify-section-{{ section.id }} .mmw-promo__logo svg { width:100%; height:100%; object-fit:contain; display:block; }
  #shopify-section-{{ section.id }} .mmw-promo__heading { font-family: var(--mmw-font-display); font-weight:400; font-size: clamp(28px,3.4vw,36px); line-height:1.1; max-width:436px; margin:0; }
  #shopify-section-{{ section.id }} .mmw-promo__btn { display:inline-flex; align-items:center; justify-content:center; min-width:150px; font-family: var(--mmw-font-label); font-weight:700; font-size:13px; letter-spacing:1.95px; text-transform:uppercase; padding:14px 47px; border-radius:30px; text-decoration:none; }
  @media (max-width:749px){
    #shopify-section-{{ section.id }} .mmw-promo__row { flex-direction:column; gap:18px; }
    #shopify-section-{{ section.id }} .mmw-promo__tile { min-height:440px; }
  }
{%- endstyle -%}
<section class="mmw-promo">
  <div class="mmw-promo__row">
    {%- for block in section.blocks -%}
      <div class="mmw-promo__tile" style="background: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }};" {{ block.shopify_attributes }}>
        {%- if block.settings.logo != blank -%}
          <div class="mmw-promo__logo"><img src="{{ block.settings.logo | image_url: width: 580 }}" alt="{{ block.settings.heading | escape }}"></div>
        {%- endif -%}
        {%- if block.settings.heading != blank -%}<p class="mmw-promo__heading">{{ block.settings.heading }}</p>{%- endif -%}
        {%- if block.settings.button_label != blank -%}
          <a class="mmw-promo__btn" href="{{ block.settings.button_url | default: '#' }}" style="background: {{ block.settings.button_bg }}; color: {{ block.settings.button_color }};">{{ block.settings.button_label }}</a>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>
{% schema %}
{
  "name": "MMW Kafle promo",
  "tag": "section",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "tile",
      "name": "Kafel",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo" },
        { "type": "textarea", "id": "heading", "label": "Nagłówek", "default": "Odwiedź naszą Winnicę i odkryj kolekcję win z największej winnicy na Mazowszu." },
        { "type": "text", "id": "button_label", "label": "Tekst przycisku", "default": "Sprawdź nasze wina" },
        { "type": "url", "id": "button_url", "label": "Link przycisku" },
        { "type": "header", "content": "Kolory" },
        { "type": "color", "id": "bg_color", "label": "Tło kafla", "default": "#c6d4e2" },
        { "type": "color", "id": "text_color", "label": "Kolor tekstu", "default": "#5f312f" },
        { "type": "color", "id": "button_bg", "label": "Tło przycisku", "default": "#5f312f" },
        { "type": "color", "id": "button_color", "label": "Tekst przycisku", "default": "#c6d4e2" }
      ]
    }
  ],
  "presets": [
    {
      "name": "MMW Kafle promo",
      "blocks": [
        { "type": "tile" },
        { "type": "tile", "settings": { "heading": "Sprawdź co oferuje czterogwiazdkowy hotel w okolicach Warszawy z własną historią.", "button_label": "Sprawdź kompleks pałacowy", "bg_color": "#5f312f", "text_color": "#faf2e8", "button_bg": "#c6d4e2", "button_color": "#5f312f" } }
      ]
    }
  ]
}
{% endschema %}
