{%- comment -%}
  mmw-category-sidebar — panel kategorii działający jako FILTR po tagu (multi-select).
  Pozycje dokładają/usuwają filter.p.tag w obrębie bieżącej kolekcji (/collections/all),
  a natywny system filtrów Horizona odświeża siatkę bez przeładowania.
  Kategorie = TAGI produktów. Włącz filtr "Product tag" w Search & Discovery.

  Menu (Content → Menus): pozycja nadrzędna = nagłówek grupy.
  Podpozycje: w polu URL wpisz, np. /collections/all?filter.p.tag=marmolady
  — z tego czytamy nazwę tagu. Tytuł pozycji = etykieta w panelu.
{%- endcomment -%}

{%- liquid
  assign menu = section.settings.menu

  assign active_tags = ''
  for filter in collection.filters
    if filter.param_name == 'filter.p.tag'
      for value in filter.active_values
        assign active_tags = active_tags | append: value.value | append: '|||'
      endfor
    endif
  endfor
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .mmw-cat {
    display: flex; flex-direction: column; gap: 40px;
    font-family: var(--mmw-font-label); color: var(--mmw-01);
    {% if section.settings.sticky %}position: sticky; top: 24px;{% endif %}
  }
  #shopify-section-{{ section.id }} .mmw-cat__crumb {
    font-weight: 700; font-size: 13px; letter-spacing: 1.95px; text-transform: uppercase; line-height: 1; margin: 0;
  }
  #shopify-section-{{ section.id }} .mmw-cat__title {
    font-family: var(--mmw-font-display); font-weight: 400; font-size: 36px; line-height: 1; margin: 0 0 27px;
  }
  #shopify-section-{{ section.id }} .mmw-cat__groups { display: flex; flex-direction: column; gap: 32px; }
  #shopify-section-{{ section.id }} .mmw-cat__group { display: flex; flex-direction: column; gap: 16px; }
  #shopify-section-{{ section.id }} .mmw-cat__group-head {
    font-weight: 700; font-size: 18px; letter-spacing: 2.7px; text-transform: uppercase; line-height: 1; margin: 0;
  }
  #shopify-section-{{ section.id }} .mmw-cat__links { display: flex; flex-direction: column; gap: 20px; list-style: none; margin: 0; padding: 0; }
  #shopify-section-{{ section.id }} .mmw-cat__links a {
    display: inline-flex; align-items: center; gap: 9px;
    font-weight: 700; font-size: 13px; letter-spacing: 1.95px; text-transform: uppercase;
    color: var(--mmw-01); text-decoration: none; transition: color .2s;
  }
  #shopify-section-{{ section.id }} .mmw-cat__links a:hover { color: var(--mmw-02); }
  #shopify-section-{{ section.id }} .mmw-cat__box {
    width: 14px; height: 14px; border: 1.5px solid var(--mmw-01); border-radius: 3px;
    display: inline-grid; place-items: center; flex-shrink: 0;
  }
  #shopify-section-{{ section.id }} .mmw-cat__box svg { width: 9px; height: 9px; opacity: 0; }
  #shopify-section-{{ section.id }} .mmw-cat__links a[aria-pressed="true"] { color: var(--mmw-02); }
  #shopify-section-{{ section.id }} .mmw-cat__links a[aria-pressed="true"] .mmw-cat__box { background: var(--mmw-02); border-color: var(--mmw-02); }
  #shopify-section-{{ section.id }} .mmw-cat__links a[aria-pressed="true"] .mmw-cat__box svg { opacity: 1; color: var(--mmw-04); }
  #shopify-section-{{ section.id }} .mmw-cat__clear {
    margin-top: 4px; font-size: 12px; letter-spacing: 1px; text-transform: uppercase;
    color: var(--mmw-01); opacity: .7; text-decoration: underline; display: inline-block;
  }

  @media (max-width: 749px) { #shopify-section-{{ section.id }} .mmw-cat { position: static; gap: 28px; } }
{%- endstyle -%}

<aside class="mmw-cat">
  {%- if section.settings.breadcrumb != blank -%}<p class="mmw-cat__crumb">{{ section.settings.breadcrumb }}</p>{%- endif -%}

  <div>
    {%- if section.settings.heading != blank -%}<p class="mmw-cat__title">{{ section.settings.heading }}</p>{%- endif -%}

    <div class="mmw-cat__groups">
      {%- if menu != blank -%}
        {%- for parent in linklists[menu].links -%}
          <div class="mmw-cat__group">
            <p class="mmw-cat__group-head">{{ parent.title }}</p>
            {%- if parent.links.size > 0 -%}
              <ul class="mmw-cat__links">
                {%- for child in parent.links -%}
                  {%- liquid
                    assign tag = ''
                    if child.url contains 'filter.p.tag='
                      assign tag = child.url | split: 'filter.p.tag=' | last | split: '&' | first | replace: '+', ' ' | url_decode
                    endif

                    assign is_active = false
                    if tag != '' and active_tags contains tag
                      assign is_active = true
                    endif

                    assign base = collection.url | default: '/collections/all'
                    assign new_params = ''
                    for filter in collection.filters
                      if filter.param_name == 'filter.p.tag'
                        for value in filter.active_values
                          unless value.value == tag
                            assign ev = value.value | url_encode
                            assign new_params = new_params | append: '&filter.p.tag=' | append: ev
                          endunless
                        endfor
                      endif
                    endfor
                    unless is_active
                      assign et = tag | url_encode
                      assign new_params = new_params | append: '&filter.p.tag=' | append: et
                    endunless
                    assign href = base | append: '?' | append: new_params | replace_first: '?&', '?'
                  -%}
                  <li>
                    <a href="{{ href }}" aria-pressed="{{ is_active }}" rel="nofollow">
                      <span class="mmw-cat__box">
                        <svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M2.5 6.5l2.5 2.5 4.5-5"/></svg>
                      </span>
                      {{ child.title }}
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endfor -%}

        {%- if active_tags != '' -%}
          <a class="mmw-cat__clear" href="{{ collection.url | default: '/collections/all' }}">Wyczyść kategorie</a>
        {%- endif -%}
      {%- else -%}
        <p class="mmw-cat__crumb">Podepnij menu w ustawieniach sekcji.</p>
      {%- endif -%}
    </div>
  </div>
</aside>

{% schema %}
{
  "name": "MMW Panel kategorii (filtr)",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "breadcrumb", "label": "Ścieżka (breadcrumb)", "default": "MAJĄTEK > SKLEP" },
    { "type": "text", "id": "heading", "label": "Nagłówek", "default": "Kategorie" },
    { "type": "link_list", "id": "menu", "label": "Menu kategorii", "info": "Nadrzędne = nagłówek grupy. Podpozycje: URL = /collections/all?filter.p.tag=NAZWA-TAGU" },
    { "type": "checkbox", "id": "sticky", "label": "Przyklejony przy scrollu", "default": true }
  ],
  "presets": [{ "name": "MMW Panel kategorii (filtr)" }]
}
{% endschema %}
