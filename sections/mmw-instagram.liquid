{%- comment -%}
  mmw-instagram — karuzela zdjęć „w stylu Instagrama", ustawiana ręcznie.
  Każdy kafel = blok (zdjęcie + opcjonalny link do posta). Zero API/tokenów.
{%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .mmw-ig {
    background: var(--mmw-03);
    padding: 40px 60px;
    display: flex; flex-direction: column; gap: 40px;
    font-family: var(--mmw-font-text);
  }
  #shopify-section-{{ section.id }} .mmw-ig__head {
    display: flex; align-items: center; justify-content: space-between; gap: 20px;
  }
  #shopify-section-{{ section.id }} .mmw-ig__title {
    margin: 0; font-family: var(--mmw-font-label); font-weight: 700;
    font-size: var(--mmw-button-size); letter-spacing: var(--mmw-label-tracking);
    text-transform: uppercase; color: var(--mmw-01); line-height: 1.3;
  }
  #shopify-section-{{ section.id }} .mmw-ig__nav { display: flex; gap: 10px; }
  #shopify-section-{{ section.id }} .mmw-ig__arrow {
    width: 44px; height: 44px; border-radius: 50%;
    border: 1.5px solid var(--mmw-01); background: transparent; color: var(--mmw-01);
    display: grid; place-items: center; cursor: pointer; transition: background .2s, color .2s;
    flex-shrink: 0;
  }
  #shopify-section-{{ section.id }} .mmw-ig__arrow:hover { background: var(--mmw-01); color: var(--mmw-03); }
  #shopify-section-{{ section.id }} .mmw-ig__arrow svg { width: 18px; height: 18px; }

  #shopify-section-{{ section.id }} .mmw-ig__track {
    display: flex; gap: 20px;
    overflow-x: auto; scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none; -ms-overflow-style: none;
    margin: 0;
    padding: 0 70px 0 100px;   /* padding przy pierwszym zdjęciu, gutter zachowany */
  }
  #shopify-section-{{ section.id }} .mmw-ig__track::-webkit-scrollbar { display: none; }

  #shopify-section-{{ section.id }} .mmw-ig__tile {
    flex: 0 0 271px; width: 271px; aspect-ratio: 271 / 290;
    border-radius: 20px; overflow: hidden; scroll-snap-align: start;
    background: var(--mmw-04); position: relative; display: block;
    text-decoration: none;
  }
  #shopify-section-{{ section.id }} .mmw-ig__tile img,
  #shopify-section-{{ section.id }} .mmw-ig__tile svg {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform .4s ease;
  }
  #shopify-section-{{ section.id }} a.mmw-ig__tile:hover img { transform: scale(1.05); }
  #shopify-section-{{ section.id }} .mmw-ig__tile-overlay {
    position: absolute; inset: 0; display: grid; place-items: center;
    background: var(--mmw-01); opacity: 0; transition: opacity .3s ease;
  }
  #shopify-section-{{ section.id }} .mmw-ig__tile-overlay {
    position: absolute; inset: 0; display: grid; place-items: center;
    background: var(--mmw-01); opacity: 0; transition: opacity .3s ease;
  }
  #shopify-section-{{ section.id }} .mmw-ig__tile-overlay svg {
    width: 34px; height: 34px;
    stroke: var(--mmw-03);
    stroke-width: 2.5;
    opacity: 0;
    transition: opacity .3s ease;
  }
  #shopify-section-{{ section.id }} a.mmw-ig__tile:hover .mmw-ig__tile-overlay {
    opacity: .25;
  }
  #shopify-section-{{ section.id }} a.mmw-ig__tile:hover .mmw-ig__tile-overlay svg {
    opacity: 1;
  }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .mmw-ig { padding: 32px 20px; gap: 24px; }
    #shopify-section-{{ section.id }} .mmw-ig__track { margin: 0 -20px; padding: 0 20px 0 40px; }
    #shopify-section-{{ section.id }} .mmw-ig__tile { flex-basis: 70%; width: 70%; }
    #shopify-section-{{ section.id }} .mmw-ig__nav { display: none; }
  }
{%- endstyle -%}

<section class="mmw-ig">
  <div class="mmw-ig__head">
    {%- if section.settings.heading != blank -%}
      <h2 class="mmw-ig__title">{{ section.settings.heading }}</h2>
    {%- endif -%}
    <div class="mmw-ig__nav">
      <button type="button" class="mmw-ig__arrow" data-dir="-1" aria-label="Poprzednie">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button type="button" class="mmw-ig__arrow" data-dir="1" aria-label="Następne">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>

  <div class="mmw-ig__track" id="mmw-ig-track-{{ section.id }}">
    {%- for block in section.blocks -%}
      {%- liquid
        assign tag = 'div'
        if block.settings.link != blank
          assign tag = 'a'
        endif
      -%}
      <{{ tag }} class="mmw-ig__tile"
        {% if block.settings.link != blank %}href="{{ block.settings.link }}" target="_blank" rel="noopener" aria-label="Zobacz post na Instagramie"{% endif %}
        {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 542 }}"
            srcset="{{ block.settings.image | image_url: width: 271 }} 271w,
                    {{ block.settings.image | image_url: width: 542 }} 542w"
            sizes="(max-width: 989px) 70vw, 271px"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy" width="271" height="290">
        {%- else -%}
          {{ 'image' | placeholder_svg_tag }}
        {%- endif -%}
        {%- if block.settings.link != blank -%}
          <span class="mmw-ig__tile-overlay">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </span>
        {%- endif -%}
      </{{ tag }}>
    {%- endfor -%}
  </div>
</section>

<script>
  (function () {
    var track = document.getElementById('mmw-ig-track-{{ section.id }}');
    if (!track) return;
    var section = track.closest('#shopify-section-{{ section.id }}');
    section.querySelectorAll('.mmw-ig__arrow').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var dir = parseInt(btn.getAttribute('data-dir'), 10);
        track.scrollBy({ left: dir * 291, behavior: 'smooth' }); /* 271 kafel + 20 gap */
      });
    });
  })();
</script>

{% schema %}
{
  "name": "MMW Instagram",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Nagłówek", "default": "ZOBACZ CO U NAS NA @MAJATEKMALAWIES" }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Zdjęcie",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Zdjęcie" },
        { "type": "url", "id": "link", "label": "Link do posta na Instagramie" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "MMW Instagram",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
