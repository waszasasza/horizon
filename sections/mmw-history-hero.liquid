{%- comment -%} mmw-history-hero — hero strony Historia. Treść z ustawień sekcji. {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} .mmw-hhero { position:relative; width:100%; min-height:{{ section.settings.height }}px; display:flex; flex-direction:column; gap:53px; align-items:center; justify-content:center; padding:80px 20px; text-align:center; overflow:hidden; }
  #shopify-section-{{ section.id }} .mmw-hhero__bg { position:absolute; inset:0; z-index:0; }
  #shopify-section-{{ section.id }} .mmw-hhero__bg img { width:100%; height:100%; object-fit:cover; }
  #shopify-section-{{ section.id }} .mmw-hhero__bg::after { content:""; position:absolute; inset:0; background: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }}); }
  #shopify-section-{{ section.id }} .mmw-hhero__inner { position:relative; z-index:1; display:flex; flex-direction:column; align-items:center; gap:53px; }
  #shopify-section-{{ section.id }} .mmw-hhero__logo { width:270px; max-width:70vw; }
  #shopify-section-{{ section.id }} .mmw-hhero__logo img, #shopify-section-{{ section.id }} .mmw-hhero__logo svg { width:100%; height:auto; display:block; }
  #shopify-section-{{ section.id }} .mmw-hhero__title { margin:0; font-family: var(--mmw-font-display); font-weight:400; font-size: clamp(48px,7vw,80px); line-height:0.97; color: var(--mmw-04); max-width:560px; }
  #shopify-section-{{ section.id }} .mmw-hhero__sub { font-family: var(--mmw-font-text); font-size:16px; line-height:1.4; color: var(--mmw-04); max-width:442px; }
  @media (max-width:749px){ #shopify-section-{{ section.id }} .mmw-hhero, #shopify-section-{{ section.id }} .mmw-hhero__inner { gap:28px; } }
{%- endstyle -%}
<section class="mmw-hhero">
  <div class="mmw-hhero__bg">{%- if section.settings.image -%}<img src="{{ section.settings.image | image_url: width: 2400 }}" alt="{{ section.settings.heading | escape }}" loading="eager" fetchpriority="high">{%- else -%}{{ 'lifestyle-1' | placeholder_svg_tag }}{%- endif -%}</div>
  <div class="mmw-hhero__inner">
    {%- if section.settings.logo != blank -%}<div class="mmw-hhero__logo"><img src="{{ section.settings.logo | image_url: width: 540 }}" alt="{{ shop.name | escape }}"></div>{%- endif -%}
    <h1 class="mmw-hhero__title">{{ section.settings.heading }}</h1>
    {%- if section.settings.subtitle != blank -%}<p class="mmw-hhero__sub">{{ section.settings.subtitle }}</p>{%- endif -%}
  </div>
</section>
{% schema %}
{
  "name": "MMW Historia hero",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Tytuł", "default": "Marka z własną filozofią" },
    { "type": "textarea", "id": "subtitle", "label": "Podtytuł", "default": "W sercu Pałacu Mała Wieś od pokoleń pielęgnowane są receptury, które dziś możemy podać na Twój stół." },
    { "type": "image_picker", "id": "image", "label": "Zdjęcie tła" },
    { "type": "image_picker", "id": "logo", "label": "Logo nad tytułem (opcjonalnie)" },
    { "type": "range", "id": "height", "min": 400, "max": 900, "step": 20, "unit": "px", "label": "Wysokość", "default": 720 },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 80, "step": 5, "unit": "%", "label": "Przyciemnienie", "default": 30 }
  ],
  "presets": [{ "name": "MMW Historia hero" }]
}
{% endschema %}
