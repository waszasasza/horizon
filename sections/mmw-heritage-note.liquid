{%- comment -%}
  mmw-heritage-note — blok tekstu SEO na dole kolekcji.
  Treść z metafielda: custom.seo_tekst (rich text), renderowana w natywnym .rte.
  Bez nagłówka — sam rich text ze stylami sklepu.
{%- endcomment -%}
{%- liquid
  assign seo = collection.metafields.custom.seo_tekst
-%}
{%- if seo != blank -%}
  {%- style -%}
    #shopify-section-{{ section.id }} .mmw-heritage {
      display: flex; justify-content: center; padding: 64px 50px; color: var(--mmw-01);
    }
    #shopify-section-{{ section.id }} .mmw-heritage .rte { max-width: 1016px; text-align: center; color: var(--mmw-01); }
    @media (max-width: 749px) { #shopify-section-{{ section.id }} .mmw-heritage { padding: 40px 20px; } }
  {%- endstyle -%}
  <section class="mmw-heritage">
    <div class="rte">{{ seo | metafield_tag }}</div>
  </section>
{%- endif -%}
{% schema %}
{
  "name": "MMW SEO Tekst",
  "tag": "section",
  "settings": [
    { "type": "paragraph", "content": "Treść z metafielda kolekcji: custom.seo_tekst (rich text). Bez nagłówka — sam tekst." }
  ],
  "presets": [{ "name": "MMW SEO Tekst" }]
}
{% endschema %}
