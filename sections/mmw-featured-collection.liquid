{%- comment -%}
  mmw-featured-collection — wyróżniona marka + produkty z jej kolekcji
    - lewy duży kafel = kolekcja marki (np. Spiżarnia Książęca), link "ODKRYJ KOLEKCJĘ"
    - prawe karty = produkty pociągnięte z tej kolekcji (zdjęcie, nazwa, cena, badge "NOWOŚĆ")
    - pusty sklep / brak kolekcji = placeholdery, żeby było widać układ
  Dane: po stworzeniu kolekcji wybierz ją w ustawieniach sekcji.
{%- endcomment -%}

{%- liquid
  assign coll = section.settings.collection
  assign limit = section.settings.products_to_show
  assign badge_tag = section.settings.new_badge_tag | downcase
  assign sample_names = 'Marmolada Jabłkowa,Miód Kwiatowy,Konfitura Malinowa,Powidła Śliwkowe,Sok Jabłkowy,Konfitura Wiśniowa' | split: ','
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .mmw-fc {
    display: flex;
    flex-direction: column;
    gap: 30px;
    width: 100%;
    max-width: 100%;
    font-family: var(--mmw-font-text);
  }

  #shopify-section-{{ section.id }} .mmw-fc__head {
    display: flex;
    flex-direction: column;
    gap: 23px;
    max-width: 609px;
    color: var(--mmw-01);
  }

  #shopify-section-{{ section.id }} .mmw-fc__title {
    margin: 0;
    font-family: var(--mmw-font-display);
    font-weight: 400;
    font-size: var(--mmw-h1-size);
    line-height: 1.1;
    color: var(--mmw-01);
  }

  #shopify-section-{{ section.id }} .mmw-fc__subtitle {
    font-size: var(--mmw-body-size);
    line-height: 1.4;
  }

  #shopify-section-{{ section.id }} .mmw-fc__subtitle p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .mmw-fc__row {
    display: grid;
    grid-template-columns: minmax(0, 371px) minmax(0, 1fr);
    gap: 28px;
    align-items: start;
    width: 100%;
  }

  /* Duży kafel marki */
  #shopify-section-{{ section.id }} .mmw-fc__feature {
    display: flex;
    flex-direction: column;
    gap: 18px;
    width: 100%;
    max-width: 371px;
    min-width: 0;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .mmw-fc__feature-img {
    flex: 1 1 auto;
    min-height: 453px;
    border-radius: 20px;
    overflow: hidden;
    background: var(--mmw-03);
  }

  #shopify-section-{{ section.id }} .mmw-fc__feature-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .mmw-fc__feature-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--mmw-01);
    font-family: var(--mmw-font-label);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--mmw-label-tracking);
    background: rgba(var(--color-foreground-rgb), 0.05);
    border: 1px solid rgba(var(--color-foreground-rgb), 0.12);
    border-radius: 999px;
    padding: 12px 20px;
    max-width: fit-content;
  }

  #shopify-section-{{ section.id }} .mmw-fc__feature-info {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .mmw-fc__feature-title {
    font-family: var(--mmw-font-display);
    font-weight: 700;
    font-size: 1.5rem;
    line-height: 1.1;
    color: var(--mmw-01);
  }

  #shopify-section-{{ section.id }} .mmw-fc__feature-label {
    font-family: var(--mmw-font-label);
    font-weight: 700;
    font-size: var(--mmw-label-size);
    letter-spacing: var(--mmw-label-tracking);
    text-transform: uppercase;
    color: var(--mmw-01);
    border-bottom: 1px solid var(--mmw-01);
    padding-bottom: 4px;
    display: inline-block;
  }

  /* Karty produktów */
  #shopify-section-{{ section.id }} .mmw-fc__products {
    width: 100%;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .mmw-fc__slideshow {
    width: 100%;
    position: relative;
  }

  #shopify-section-{{ section.id }} .mmw-fc__slideshow slideshow-slides {
    gap: 28px;
    margin-block: -16px;
    padding-block: 16px;
  }

  #shopify-section-{{ section.id }} .mmw-fc__slide {
    display: flex;
    justify-content: center;
    width: min(271px, 100%);
    flex: 0 0 auto;
  }

  #shopify-section-{{ section.id }} .mmw-fc__slideshow slideshow-arrows {
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0;
    padding-inline: 0;
  }

  #shopify-section-{{ section.id }} .mmw-fc__slideshow slideshow-arrows .slideshow-control {
    opacity: 1;
  }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mmw-fc__slide {
      width: 100%;
    }

    #shopify-section-{{ section.id }} .mmw-fc__slideshow slideshow-arrows {
      opacity: 1;
      padding-bottom: 50px;
    }

    #shopify-section-{{ section.id }} .mmw-fc__slideshow slideshow-arrows .slideshow-control {
      opacity: 1;
    }
  }

  #shopify-section-{{ section.id }} .mmw-fc__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 18px;
    width: min(271px, 100%);
    min-width: 0;
    text-decoration: none;
    border-radius: 20px;
    overflow: hidden;
    background: var(--color-surface);
    transition: transform var(--hover-transition-duration) var(--hover-transition-timing), box-shadow var(--hover-transition-duration) var(--hover-transition-timing);
  }

  #shopify-section-{{ section.id }} .mmw-fc__card:hover,
  #shopify-section-{{ section.id }} .mmw-fc__card:focus-within {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  #shopify-section-{{ section.id }} .mmw-fc__card-img {
    position: relative;
    height: 290px;
    border-radius: 20px 20px 0 0;
    overflow: hidden;
    background: var(--mmw-03);
  }

  #shopify-section-{{ section.id }} .mmw-fc__card-img img,
  #shopify-section-{{ section.id }} .mmw-fc__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .mmw-fc__badge {
    position: absolute;
    top: 16px;
    right: 16px;
    background: var(--mmw-03);
    color: var(--mmw-01);
    font-family: var(--mmw-font-label);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: var(--mmw-label-tracking);
    text-transform: uppercase;
    padding: 8px 11px;
    border-radius: 58px;
  }

  #shopify-section-{{ section.id }} .mmw-fc__meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: var(--font-size--body-md);
    letter-spacing: normal;
    text-transform: none;
    color: var(--color-foreground);
    padding: 0 16px 20px;
  }

  #shopify-section-{{ section.id }} .mmw-fc__name {
    font-weight: 600;
    font-size: var(--font-size--body-md);
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .mmw-fc__price {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-foreground-muted);
  }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .mmw-fc {
      gap: 24px;
    }

    #shopify-section-{{ section.id }} .mmw-fc__title {
      font-size: 40px;
    }

    #shopify-section-{{ section.id }} .mmw-fc__row {
      grid-template-columns: 1fr;
    }

    #shopify-section-{{ section.id }} .mmw-fc__feature {
      width: 100%;
      max-width: 100%;
    }

    #shopify-section-{{ section.id }} .mmw-fc__feature-img {
      min-height: 300px;
    }

    #shopify-section-{{ section.id }} .mmw-fc__products {
      margin: 0;
      padding: 0;
    }

    #shopify-section-{{ section.id }} .mmw-fc__card {
      width: min(271px, 100%);
      flex: 0 0 auto;
    }
  }
{%- endstyle -%}

<section
  class="section section--page-width color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>

  <div class="mmw-fc">
    <div class="mmw-fc__head">
      {%- if section.settings.heading != blank -%}
        <h2 class="mmw-fc__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="mmw-fc__subtitle">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    <div class="mmw-fc__row">
      {%- comment -%} Duży kafel marki {%- endcomment -%}
      <a class="mmw-fc__feature" href="{{ coll.url | default: '#' }}">
        <div class="mmw-fc__feature-img">
          {%- if section.settings.feature_image != blank -%}
            <img src="{{ section.settings.feature_image | image_url: width: 800 }}" alt="" loading="lazy" width="742" height="906">
          {%- elsif coll.featured_image != blank -%}
            <img src="{{ coll.featured_image | image_url: width: 800 }}" alt="{{ coll.title | escape }}" loading="lazy" width="742" height="906">
          {%- else -%}
            {{ 'collection-1' | placeholder_svg_tag: 'mmw-fc__placeholder' }}
          {%- endif -%}
        </div>
        <div class="mmw-fc__feature-info">
          {%- if coll.title != blank -%}
            <span class="mmw-fc__feature-title">{{ coll.title }}</span>
          {%- endif -%}
          {%- if section.settings.feature_label != blank -%}
            <span class="mmw-fc__feature-button">{{ section.settings.feature_label }}</span>
          {%- endif -%}
        </div>
      </a>

      {%- comment -%} Karty produktów {%- endcomment -%}
      <div class="mmw-fc__products">
        {%- assign slide_count = 0 -%}

        {%- capture slides -%}
          {%- if coll != blank and coll.all_products_count > 0 -%}
            {%- for product in coll.products limit: limit -%}
              {%- assign slide_count = slide_count | plus: 1 -%}
              <slideshow-slide
                ref="slides[]"
                aria-hidden="{%- if forloop.first -%}false{%- else -%}true{%- endif -%}"
                class="mmw-fc__slide"
                slide-id="slide-{{ forloop.index0 }}"
                media-fit="cover"
                style="--slideshow-timeline: --slide-{{ forloop.index0 }};"
              >
                <a class="mmw-fc__card" href="{{ product.url }}">
                  <div class="mmw-fc__card-img">
                    {%- if product.featured_image != blank -%}
                      <img src="{{ product.featured_image | image_url: width: 560 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="271" height="290">
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'mmw-fc__placeholder' }}
                    {%- endif -%}
                    {%- if badge_tag != blank and product.tags contains badge_tag -%}
                      <span class="mmw-fc__badge">{{ section.settings.new_badge_label }}</span>
                    {%- endif -%}
                  </div>
                  <div class="mmw-fc__meta">
                    <span class="mmw-fc__name">{{ product.title }}</span>
                    <span class="mmw-fc__price">{{ product.price | money }}</span>
                  </div>
                </a>
              </slideshow-slide>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..limit) -%}
              {%- assign slide_count = slide_count | plus: 1 -%}
              {%- assign ph_index = forloop.index | modulo: 6 | plus: 1 -%}
              <slideshow-slide
                ref="slides[]"
                aria-hidden="{%- if forloop.first -%}false{%- else -%}true{%- endif -%}"
                class="mmw-fc__slide"
                slide-id="slide-{{ forloop.index0 }}"
                media-fit="cover"
                style="--slideshow-timeline: --slide-{{ forloop.index0 }};"
              >
                <div class="mmw-fc__card">
                  <div class="mmw-fc__card-img">
                    {{ 'product-' | append: ph_index | placeholder_svg_tag: 'mmw-fc__placeholder' }}
                  </div>
                  <div class="mmw-fc__meta">
                    <span class="mmw-fc__name">{{ sample_names[forloop.index0] | default: 'Produkt' }}</span>
                    <span class="mmw-fc__price">38 zł</span>
                  </div>
                </div>
              </slideshow-slide>
            {%- endfor -%}
          {%- endif -%}
        {%- endcapture -%}

        {%- render 'slideshow'
          , slides: slides
          , slide_count: slide_count
          , slideshow_gutters: 'start end'
          , show_arrows: true
          , icon_style: 'arrow'
          , icon_shape: 'circle'
          , arrows_position: 'center'
          , class: 'mmw-fc__slideshow'
          , style: '--slideshow-align-items: stretch; --gutter-slide-width: 28px;'
        -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MMW Wyróżniona marka",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Nagłówek", "default": "Poznaj Świat Majątku" },
    { "type": "richtext", "id": "description", "label": "Opis", "default": "<p>Smaki, aromaty i historie zamknięte w markach tworzonych w sercu Majątku Mała Wieś. Poznaj je wszystkie.</p>" },
    { "type": "collection", "id": "collection", "label": "Kolekcja marki (np. Spiżarnia Książęca)" },
    { "type": "image_picker", "id": "feature_image", "label": "Zdjęcie dużego kafla (opcjonalnie — domyślnie zdjęcie kolekcji)" },
    { "type": "text", "id": "feature_label", "label": "Etykieta kafla", "default": "ODKRYJ KOLEKCJĘ" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 6, "step": 1, "label": "Liczba produktów", "default": 3 },
    { "type": "header", "content": "Badge NOWOŚĆ" },
    { "type": "text", "id": "new_badge_label", "label": "Tekst badge", "default": "NOWOŚĆ" },
    { "type": "text", "id": "new_badge_tag", "label": "Tag produktu uruchamiający badge", "default": "nowość", "info": "Produkty z tym tagiem dostaną badge w rogu zdjęcia." }
  ],
  "presets": [
    {
      "name": "MMW Wyróżniona marka",
      "settings": {
        "heading": "Poznaj Świat Majątku",
        "feature_label": "ODKRYJ KOLEKCJĘ",
        "products_to_show": 3
      }
    }
  ]
}
{% endschema %}
