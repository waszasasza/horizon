{%- comment -%}
  mmw-article-products — "Produkty o których wspominamy".
  Lista produktów z metafielda artykułu: custom.powiazane_produkty (product list).
  Renderuje reużywalną kartę mmw-product-card + przycisk.
{%- endcomment -%}
{%- liquid
  assign produkty = article.metafields.custom.powiazane_produkty.value
-%}
{%- if produkty != blank and produkty.size > 0 -%}
{%- style -%}
  #shopify-section-{{ section.id }} .mmw-aprod { display:flex; flex-direction:column; align-items:center; gap:42px; padding-block:50px; padding-inline: max(var(--page-margin, 40px), calc((100% - var(--mmw-article-width, 1240px)) / 2)); }
  #shopify-section-{{ section.id }} .mmw-aprod__head {
    font-family: var(--mmw-font-label); font-weight:700; font-size:18px;
    letter-spacing: var(--mmw-label-tracking); text-transform:uppercase; color: var(--mmw-01); text-align:center; margin:0;
  }
  #shopify-section-{{ section.id }} .mmw-aprod__grid { display:flex; gap:42px; flex-wrap:wrap; justify-content:center; }
    position:absolute; top:16px; right:16px; background: var(--mmw-03); color: var(--mmw-01);
    font-family: var(--mmw-font-label); font-weight:700; font-size:12px; letter-spacing:1.8px; text-transform:uppercase;
    padding:8px 11px; border-radius:58px;
  }
    font-family: var(--mmw-font-label); font-weight:700; font-size:13px; letter-spacing:1.95px; text-transform:uppercase; color: var(--mmw-01);
  }
  #shopify-section-{{ section.id }} a.mmw-aprod__btn {
    display:inline-flex; align-items:center; justify-content:center; background: var(--mmw-01); color: var(--mmw-04);
    font-family: var(--mmw-font-label); font-weight:700; font-size:13px; letter-spacing:1.95px; text-transform:uppercase;
    padding:20px 45px; border-radius:30px; text-decoration:none;
  }
{%- endstyle -%}
<section class="mmw-aprod">
  <p class="mmw-aprod__head">{{ section.settings.heading }}</p>
  <div class="mmw-aprod__grid">
    {%- for product in produkty -%}
      {% render 'mmw-product-card', product: product %}
    {%- endfor -%}
  </div>
  {%- if section.settings.button_label != blank -%}
    <a class="mmw-aprod__btn" href="{{ section.settings.button_url | default: '/collections/all' }}">{{ section.settings.button_label }}</a>
  {%- endif -%}
</section>
{%- endif -%}
{% schema %}
{
  "name": "MMW Produkty wpisu",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Nagłówek", "default": "Produkty o których wspominamy w tym artykule" },
    { "type": "text", "id": "button_label", "label": "Tekst przycisku", "default": "Sprawdź więcej produktów" },
    { "type": "url", "id": "button_url", "label": "Link przycisku" },
    { "type": "paragraph", "content": "Produkty z metafielda artykułu: custom.powiazane_produkty (lista odwołań do produktów)." }
  ],
  "presets": [{ "name": "MMW Produkty wpisu" }]
}
{% endschema %}
