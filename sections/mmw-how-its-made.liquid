{%- comment -%}
  mmw-how-its-made — „Sprawdź jak powstają nasze produkty"
  Ramka (border --mmw-01, rounded) z tekstem (wyśrodkowanym) po lewej i zdjęciem po prawej.
{%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .mmw-him {
    display: flex; justify-content: center;
    padding-block: 50px; padding-inline: var(--page-margin, 40px); font-family: var(--mmw-font-text);
  }
  #shopify-section-{{ section.id }} .mmw-him__card {
    display: flex; align-items: center; gap: 120px;
    width: 100%;
    border: 2px solid var(--mmw-01); border-radius: 20px;
    padding: 40px;
    text-decoration: none; color: inherit;
    transition: background-color .3s ease, transform .3s ease, box-shadow .3s ease;
  }
  #shopify-section-{{ section.id }} a.mmw-him__card:hover {
    background: var(--mmw-03);
    transform: translateY(-6px);
    box-shadow: 0 14px 30px rgba(95,49,47,.15);
  }
  #shopify-section-{{ section.id }} .mmw-him__copy {
    flex: 0 1 457px;
    display: flex; flex-direction: column; align-items: center; gap: 20px;
    text-align: center; color: var(--mmw-01);
  }
  #shopify-section-{{ section.id }} .mmw-him__title {
    margin: 0; font-size: var(--font-h2--size); color: var(--mmw-01);
  }
  #shopify-section-{{ section.id }} .mmw-him__text {
    max-width: 335px; font-family: var(--mmw-font-text);
    font-size: var(--font-paragraph--size); line-height: var(--font-paragraph--line-height, 1.4);
  }
  #shopify-section-{{ section.id }} .mmw-him__text p { margin: 0; }
  #shopify-section-{{ section.id }} .mmw-him__media {
    flex: 0 1 585px; aspect-ratio: 585 / 429;
    border-radius: 20px; overflow: hidden; background: var(--mmw-03);
  }
  #shopify-section-{{ section.id }} .mmw-him__media img,
  #shopify-section-{{ section.id }} .mmw-him__media svg {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .mmw-him { padding: 32px 20px; }
    #shopify-section-{{ section.id }} .mmw-him__card { flex-direction: column; gap: 32px; padding: 28px; }
    #shopify-section-{{ section.id }} .mmw-him__copy { flex: 1 1 auto; }
    #shopify-section-{{ section.id }} .mmw-him__media { flex: 1 1 auto; width: 100%; }
  }
{%- endstyle -%}

<section class="mmw-him">
  {%- if section.settings.link != blank -%}
    <a class="mmw-him__card" href="{{ section.settings.link }}">
  {%- else -%}
    <div class="mmw-him__card">
  {%- endif -%}
    <div class="mmw-him__copy">
      {%- if section.settings.heading != blank -%}
        <h2 class="mmw-him__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="mmw-him__text">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    <div class="mmw-him__media">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1170 }}"
          srcset="{{ section.settings.image | image_url: width: 585 }} 585w,
                  {{ section.settings.image | image_url: width: 1170 }} 1170w"
          sizes="(max-width: 989px) 90vw, 585px"
          alt="{{ section.settings.image.alt | escape }}"
          loading="lazy" width="585" height="429">
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag }}
      {%- endif -%}
    </div>
  {%- if section.settings.link != blank -%}
    </a>
  {%- else -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "MMW Jak powstają",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Nagłówek", "default": "Sprawdź jak powstają nasze produkty" },
    { "type": "richtext", "id": "description", "label": "Tekst", "default": "<p>W sercu Pałacu Mała Wieś od pokoleń pielęgnowane są receptury, które dziś możemy podać na Twój stół.</p>" },
    { "type": "image_picker", "id": "image", "label": "Zdjęcie" },
    { "type": "url", "id": "link", "label": "Link całej sekcji (opcjonalnie)" }
  ],
  "presets": [
    {
      "name": "MMW Jak powstają",
      "settings": {
        "heading": "Sprawdź jak powstają nasze produkty",
        "description": "<p>W sercu Pałacu Mała Wieś od pokoleń pielęgnowane są receptury, które dziś możemy podać na Twój stół.</p>"
      }
    }
  ]
}
{% endschema %}
