{%- comment -%} mmw-philosophy — "Nasza filozofia": eyebrow + duży cytat + rząd zdjęć (bloki). {%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} .mmw-phil { display:flex; flex-direction:column; gap:30px; align-items:center; padding-block:50px; padding-inline: var(--page-margin, 40px); }
  #shopify-section-{{ section.id }} .mmw-phil__eyebrow { font-family: var(--mmw-font-label); font-weight:700; font-size:18px; letter-spacing: var(--mmw-label-tracking); text-transform:uppercase; color: var(--mmw-01); margin:0; }
  #shopify-section-{{ section.id }} .mmw-phil__quote { font-family: var(--mmw-font-display); font-weight:400; font-size: clamp(34px,4.4vw,64px); line-height:1.1; color: var(--mmw-01); text-align:center; max-width:775px; margin:0 0 40px; }
  #shopify-section-{{ section.id }} .mmw-phil__imgs { display:flex; gap:36px; justify-content:center; flex-wrap:wrap; }
  #shopify-section-{{ section.id }} .mmw-phil__img { flex:0 0 375px; max-width:100%; aspect-ratio: 375 / 489; border-radius:13px; overflow:hidden; }
  #shopify-section-{{ section.id }} .mmw-phil__img img, #shopify-section-{{ section.id }} .mmw-phil__img svg { width:100%; height:100%; object-fit:cover; display:block; }
@media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mmw-phil__imgs {
      flex-direction: column;
      align-items: center;
      gap: 20px;
    }
    #shopify-section-{{ section.id }} .mmw-phil__img {
      flex: 0 0 auto;
      width: 100%;
      max-width: 420px;
      aspect-ratio: 3 / 4;
    }
  }
{%- endstyle -%}
<section class="mmw-phil">
  {%- if section.settings.eyebrow != blank -%}<p class="mmw-phil__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
  {%- if section.settings.quote != blank -%}<p class="mmw-phil__quote">{{ section.settings.quote }}</p>{%- endif -%}
  {%- if section.blocks.size > 0 -%}
    <div class="mmw-phil__imgs">
      {%- for block in section.blocks -%}
        <div class="mmw-phil__img" {{ block.shopify_attributes }}>{%- if block.settings.image -%}<img src="{{ block.settings.image | image_url: width: 750 }}" alt="" loading="lazy">{%- else -%}{{ 'image' | placeholder_svg_tag }}{%- endif -%}</div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>
{% schema %}
{
  "name": "MMW Filozofia",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Etykieta", "default": "Nasza filozofia" },
    { "type": "textarea", "id": "quote", "label": "Cytat (duży tekst)", "default": "W samym centrum Pałacu Mała Wieś od pokoleń pielęgnujemy tradycyjne receptury, które dziś z dumą podajemy na Twój stół." }
  ],
  "blocks": [ { "type": "photo", "name": "Zdjęcie", "settings": [ { "type": "image_picker", "id": "image", "label": "Zdjęcie" } ] } ],
  "presets": [{ "name": "MMW Filozofia", "blocks": [ {"type":"photo"},{"type":"photo"},{"type":"photo"} ] }]
}
{% endschema %}
