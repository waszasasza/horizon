{%- comment -%}
  mmw-team — "Team handlowy". Eyebrow + karty osób (blok = osoba: zdjęcie, imię, stanowisko, e-mail).
  Edytowalne w theme editorze. Reuse stylu kart (zdjęcie rounded-13, Roslindale).
{%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} .mmw-team { display:flex; flex-direction:column; gap:35px; padding-block:40px; padding-inline: var(--page-margin, 40px); }
  #shopify-section-{{ section.id }} .mmw-team__eyebrow { font-family: var(--mmw-font-label); font-weight:700; font-size:18px; letter-spacing: var(--mmw-label-tracking, 2.7px); text-transform:uppercase; color: var(--mmw-01); margin:0; }
  #shopify-section-{{ section.id }} .mmw-team__grid { display:grid; grid-template-columns: repeat(3, 1fr); gap:60px; }
  #shopify-section-{{ section.id }} .mmw-team__card { display:flex; flex-direction:column; gap:13px; }
  #shopify-section-{{ section.id }} .mmw-team__img { width:100%; aspect-ratio: 355 / 429; border-radius:13px; overflow:hidden; background: var(--mmw-04); }
  #shopify-section-{{ section.id }} .mmw-team__img img, #shopify-section-{{ section.id }} .mmw-team__img svg { width:100%; height:100%; object-fit:cover; display:block; }
  #shopify-section-{{ section.id }} .mmw-team__name { font-family: var(--mmw-font-display); font-weight:400; font-size:36px; line-height:1; color: var(--mmw-01); margin:0; }
  #shopify-section-{{ section.id }} .mmw-team__id { display:flex; flex-direction:column; gap:4px; }
  #shopify-section-{{ section.id }} .mmw-team__role { margin:0; font-family: var(--mmw-font-label); font-weight:700; font-size:14px; letter-spacing: var(--mmw-label-tracking); text-transform:uppercase; }
  #shopify-section-{{ section.id }} .mmw-team__email { font-family: var(--mmw-font-text); font-size:14px; line-height:1.3; color: var(--mmw-01); margin:0; text-decoration:none; word-break:break-word; }
  @media (max-width:989px){ #shopify-section-{{ section.id }} .mmw-team__grid { grid-template-columns: repeat(2, 1fr); gap:32px; } }
  @media (max-width:649px){ #shopify-section-{{ section.id }} .mmw-team__grid { grid-template-columns: 1fr; } }
{%- endstyle -%}
<section class="mmw-team">
  {%- if section.settings.eyebrow != blank -%}<p class="mmw-team__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
  {%- if section.blocks.size > 0 -%}
    <div class="mmw-team__grid">
      {%- for block in section.blocks -%}
        <div class="mmw-team__card" {{ block.shopify_attributes }}>
          <div class="mmw-team__img">
            {%- if block.settings.image -%}<img src="{{ block.settings.image | image_url: width: 720 }}" alt="{{ block.settings.name | escape }}" loading="lazy">{%- else -%}{{ 'image' | placeholder_svg_tag }}{%- endif -%}
          </div>
          <div class="mmw-team__id">
            <p class="mmw-team__name">{{ block.settings.name }}</p>
            {%- if block.settings.role != blank -%}<h6 class="mmw-team__role">{{ block.settings.role }}</h6>{%- endif -%}
          </div>
          {%- if block.settings.email != blank -%}<a class="mmw-team__email" href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>
{% schema %}
{
  "name": "MMW Zespół",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Etykieta", "default": "Team handlowy" }
  ],
  "blocks": [
    {
      "type": "person",
      "name": "Osoba",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Zdjęcie" },
        { "type": "text", "id": "name", "label": "Imię i nazwisko", "default": "Eugenia Havryk" },
        { "type": "text", "id": "role", "label": "Stanowisko", "default": "Dyrektor Sprzedaży" },
        { "type": "text", "id": "email", "label": "E-mail", "default": "e.havryk@majatekmalawies.pl" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{ "name": "MMW Zespół", "blocks": [ {"type":"person"},{"type":"person"},{"type":"person"} ] }]
}
{% endschema %}
