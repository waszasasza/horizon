{%- comment -%}
  mmw-footer — stopka Majątku Mała Wieś.
  Newsletter (natywny formularz klienta Shopify), 3 kolumny linków (menu),
  logo (upload), copyright + social. Dodaj do sections/footer-group.json, by była site-wide.
{%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .mmw-ft {
    background: var(--mmw-01); color: var(--mmw-04);
    padding: 70px; display: flex; flex-direction: column; gap: 55px;
    font-family: var(--mmw-font-text);
    background-repeat: no-repeat;
    background-size: cover;
    background-position: center;
  }
  #shopify-section-{{ section.id }} .mmw-ft__made-by {
    color: var(--mmw-04);
    text-decoration: underline;
    margin-right: 10px;
  }
  #shopify-section-{{ section.id }} .mmw-ft__top {
    display: flex; flex-direction: column; gap: 100px;
  }
  #shopify-section-{{ section.id }} .mmw-ft__row {
    display: flex; justify-content: space-between; gap: 80px; flex-wrap: wrap;
  }

  /* Newsletter */
  #shopify-section-{{ section.id }} .mmw-ft__news { max-width: 527px; display: flex; flex-direction: column; gap: 27px; }
  #shopify-section-{{ section.id }} .mmw-ft__news-head { display: flex; flex-direction: column; gap: 12px; }
  #shopify-section-{{ section.id }} .mmw-ft__eyebrow {
    font-family: var(--mmw-font-label); font-weight: 700; font-size: var(--mmw-button-size);
    letter-spacing: var(--mmw-label-tracking); text-transform: uppercase; line-height: 1.3; margin: 0;
  }
  #shopify-section-{{ section.id }} .mmw-ft__news-text { font-size: var(--mmw-body-size); max-width: 335px; margin: 0; }
  #shopify-section-{{ section.id }} .mmw-ft__form {
    display: flex; gap: 12px; align-items: center; flex-wrap: wrap;
  }
  #shopify-section-{{ section.id }} .mmw-ft__input {
    flex: 1 1 0%; min-width: 260px;
    background: transparent; color: var(--mmw-04);
    border: 1px solid var(--mmw-04); border-radius: 50px;
    padding: 16px 20px;
    font-family: var(--mmw-font-label); font-weight: 700; font-size: 13px;
    letter-spacing: 1.95px; text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .mmw-ft__input::placeholder { color: var(--mmw-04); opacity: .85; }
  #shopify-section-{{ section.id }} .mmw-ft__submit {
    background: var(--mmw-02); color: var(--mmw-04); border: none;
    border-radius: 50px; padding: 16px 46px; cursor: pointer;
    font-family: var(--mmw-font-label); font-weight: 700; font-size: 13px;
    letter-spacing: 1.95px; text-transform: uppercase; transition: opacity .2s;
    flex: 0 0 auto;
    white-space: nowrap;
  }
  @media (max-width: 620px) {
    #shopify-section-{{ section.id }} .mmw-ft__form {
      flex-direction: column;
      align-items: stretch;
    }
    #shopify-section-{{ section.id }} .mmw-ft__input,
    #shopify-section-{{ section.id }} .mmw-ft__submit {
      flex: 1 1 100%;
      width: 100%;
    }
    #shopify-section-{{ section.id }} .mmw-ft__cols { flex-direction: column; text-align: center; }
    #shopify-section-{{ section.id }} .mmw-ft__col { width: 100%; min-width: 0; align-items: center; }
    #shopify-section-{{ section.id }} .mmw-ft__links { align-items: center; }
  }
  #shopify-section-{{ section.id }} .mmw-ft__submit:hover { opacity: .88; }
  #shopify-section-{{ section.id }} .mmw-ft__note { font-size: 13px; margin: 8px 0 0; opacity: .9; }

  /* Kolumny linków */
  #shopify-section-{{ section.id }} .mmw-ft__cols { display: flex; gap: 69px; flex-wrap: wrap; }
  #shopify-section-{{ section.id }} .mmw-ft__col { display: flex; flex-direction: column; gap: 29px; }
  #shopify-section-{{ section.id }} .mmw-ft__col-head {
    font-family: var(--mmw-font-label); font-weight: 700; font-size: var(--mmw-button-size);
    letter-spacing: var(--mmw-label-tracking); text-transform: uppercase; margin: 0; line-height: 1.3;
  }
  #shopify-section-{{ section.id }} .mmw-ft__links { display: flex; flex-direction: column; gap: 17px; list-style: none; margin: 0; padding: 0; }
  #shopify-section-{{ section.id }} .mmw-ft__links a {
    color: var(--mmw-04); font-size: 14px; text-decoration: underline; text-underline-position: from-font;
  }
  #shopify-section-{{ section.id }} .mmw-ft__links a:hover { color: var(--mmw-02); }

  /* Logo */
  #shopify-section-{{ section.id }} .mmw-ft__logo { width: 100%; display: flex; justify-content: center; }
  #shopify-section-{{ section.id }} .mmw-ft__logo img { width: 100%; max-width: 1300px; height: auto; display: block; transition: transform .2s ease; }
  #shopify-section-{{ section.id }} .mmw-ft__logo svg { width: 100%; max-width: 1300px; height: auto; }

  /* Dół */
  #shopify-section-{{ section.id }} .mmw-ft__bottom { display: flex; justify-content: space-between; align-items: center; gap: 20px; flex-wrap: wrap; }
  #shopify-section-{{ section.id }} .mmw-ft__copy { font-family: 'Inter', sans-serif; font-size: 11px; line-height: 1.6; margin: 0; }
  #shopify-section-{{ section.id }} .mmw-ft__copy a { color: var(--mmw-04); text-decoration: underline; }
  #shopify-section-{{ section.id }} .mmw-ft__social { display: flex; gap: 11px; align-items: center; }
  #shopify-section-{{ section.id }} .mmw-ft__social a { color: var(--mmw-04); display: inline-flex; transition: color .2s; }
  #shopify-section-{{ section.id }} .mmw-ft__social a:hover { color: var(--mmw-02); }
  #shopify-section-{{ section.id }} .mmw-ft__social svg { width: 22px; height: 22px; }

  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .mmw-ft { padding: 40px 20px; gap: 40px; }
    #shopify-section-{{ section.id }} .mmw-ft__top { gap:46px; }
    #shopify-section-{{ section.id }} .mmw-ft__row {
      flex-direction: column;
      justify-content: center;
      align-items: stretch;
    }
    #shopify-section-{{ section.id }} .mmw-ft__news {
      width: min(527px, 100%);
      margin: 0 auto;
      align-items: stretch;
    }
    #shopify-section-{{ section.id }} .mmw-ft__logo {
      width: 100%;
      padding: 0 40px;
      align-items: stretch;
    }
    #shopify-section-{{ section.id }} .mmw-ft__cols {
      gap: 32px;
      justify-content: center;
      align-items: stretch;
    }
    #shopify-section-{{ section.id }} .mmw-ft__col {
      flex: 1 1 min(160px, 100%);
      min-width: 160px;
      align-items: center;
    }
    #shopify-section-{{ section.id }} .mmw-ft__bottom {
      flex-direction: column-reverse;
      align-items: center;
      padding:40px;
    }
    #shopify-section-{{ section.id }} .mmw-ft__copy { text-align: center; width: 100%; }
    #shopify-section-{{ section.id }} .mmw-ft__social { justify-content: center; width: 100%; }
  }

{%- endstyle -%}

<footer class="mmw-ft mmw-pattern">
  <div class="mmw-ft__top">
    <div class="mmw-ft__row">
      {%- comment -%} Newsletter {%- endcomment -%}
      <div class="mmw-ft__news">
        <div class="mmw-ft__news-head">
          {%- if section.settings.news_heading != blank -%}<p class="mmw-ft__eyebrow">{{ section.settings.news_heading }}</p>{%- endif -%}
          {%- if section.settings.news_text != blank -%}<p class="mmw-ft__news-text">{{ section.settings.news_text }}</p>{%- endif -%}
        </div>
        {%- form 'customer' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="mmw-ft__form">
            <input type="email" name="contact[email]" class="mmw-ft__input"
              placeholder="{{ section.settings.input_placeholder | escape }}"
              required aria-label="Adres e-mail">
            <button type="submit" class="mmw-ft__submit">{{ section.settings.submit_label }}</button>
          </div>
          {%- if form.posted_successfully? -%}
            <p class="mmw-ft__note">Dziękujemy — zapisaliśmy Twój adres!</p>
          {%- elsif form.errors -%}
            <p class="mmw-ft__note">{{ form.errors.translated_fields.email }} {{ form.errors.messages.email }}</p>
          {%- endif -%}
        {%- endform -%}
      </div>

      {%- comment -%} Kolumny linków (menu) {%- endcomment -%}
      <div class="mmw-ft__cols">
        {%- for i in (1..3) -%}
          {%- liquid
            assign head_key = 'col_' | append: i | append: '_heading'
            assign menu_key = 'col_' | append: i | append: '_menu'
            assign head = section.settings[head_key]
            assign menu = section.settings[menu_key]
          -%}
          {%- if head != blank or menu != blank -%}
            <div class="mmw-ft__col">
              {%- if head != blank -%}<p class="mmw-ft__col-head">{{ head }}</p>{%- endif -%}
              {%- if menu != blank -%}
                <ul class="mmw-ft__links">
                  {%- for link in linklists[menu].links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} Logo {%- endcomment -%}
    {%- if section.settings.logo != blank -%}
      <div class="mmw-ft__logo">
        <img src="{{ section.settings.logo | image_url: width: 2600 }}"
             alt="{{ shop.name | escape }}" width="2600" height="400" loading="lazy">
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Dół: copyright + social {%- endcomment -%}
  <div class="mmw-ft__bottom">
    <p class="mmw-ft__copy">
      {%- if section.settings.made_by_link != blank -%}
        <a href="{{ section.settings.made_by_link }}" class="mmw-ft__made-by" target="_blank" rel="noopener">Made by Suprematic</a>
      {%- else -%}
        <span class="mmw-ft__made-by">Made by Suprematic</span>
      {%- endif -%}
      © {{ 'now' | date: '%Y' }} {{ shop.name }}, <a href="https://www.shopify.com" target="_blank" rel="noopener">Powered by Shopify</a>
    </p>
    <div class="mmw-ft__social">
      {%- if section.settings.social_facebook != blank -%}
        <a href="{{ section.settings.social_facebook }}" target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H9v3h2v6h3v-6h2.5l.5-3H14V9c0-.6.4-1 1-1z"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.social_instagram != blank -%}
        <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.social_youtube != blank -%}
        <a href="{{ section.settings.social_youtube }}" target="_blank" rel="noopener" aria-label="YouTube">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 8.2a2.6 2.6 0 0 0-1.8-1.8C18.6 6 12 6 12 6s-6.6 0-8.2.4A2.6 2.6 0 0 0 2 8.2 27 27 0 0 0 1.6 12 27 27 0 0 0 2 15.8a2.6 2.6 0 0 0 1.8 1.8C5.4 18 12 18 12 18s6.6 0 8.2-.4a2.6 2.6 0 0 0 1.8-1.8A27 27 0 0 0 22.4 12 27 27 0 0 0 22 8.2zM10 15V9l5 3z"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.social_tiktok != blank -%}
        <a href="{{ section.settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 3c.3 2 1.6 3.6 3.6 3.9v2.8c-1.3.1-2.6-.3-3.6-1v5.8a5.5 5.5 0 1 1-5.5-5.5c.3 0 .6 0 .9.1v2.9a2.6 2.6 0 1 0 1.8 2.5V3z"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.social_twitter != blank -%}
        <a href="{{ section.settings.social_twitter }}" target="_blank" rel="noopener" aria-label="X">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 3h3l-6.6 7.5L21.8 21h-5.9l-4.3-5.6L6.5 21H3.5l7-8L2.5 3h6l3.9 5.2zM16.4 19.2h1.7L7.7 4.7H5.9z"/></svg>
        </a>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "MMW Stopka",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Newsletter" },
    { "type": "text", "id": "news_heading", "label": "Nagłówek", "default": "ZAPISZ SIĘ DO NEWSLETTERA" },
    { "type": "text", "id": "news_text", "label": "Tekst", "default": "Zgarniaj promocje i dowiedz się o nowościach, prosto na twoją skrzynkę!" },
    { "type": "text", "id": "input_placeholder", "label": "Placeholder pola e-mail", "default": "ADRES E-MAIL" },
    { "type": "text", "id": "submit_label", "label": "Tekst przycisku", "default": "DOŁĄCZ" },

    { "type": "header", "content": "Kolumna 1" },
    { "type": "text", "id": "col_1_heading", "label": "Nagłówek", "default": "MAJĄTEK" },
    { "type": "link_list", "id": "col_1_menu", "label": "Menu" },

    { "type": "header", "content": "Kolumna 2" },
    { "type": "text", "id": "col_2_heading", "label": "Nagłówek", "default": "PRODUKTY" },
    { "type": "link_list", "id": "col_2_menu", "label": "Menu" },

    { "type": "header", "content": "Kolumna 3" },
    { "type": "text", "id": "col_3_heading", "label": "Nagłówek", "default": "POMOC" },
    { "type": "link_list", "id": "col_3_menu", "label": "Menu" },

    { "type": "header", "content": "Logo" },
    { "type": "image_picker", "id": "logo", "label": "Logo (napis MAJĄTEK MAŁA WIEŚ)" },
    { "type": "url", "id": "made_by_link", "label": "Link Made by Suprematic" },

    { "type": "header", "content": "Social media" },
    { "type": "url", "id": "social_facebook", "label": "Facebook" },
    { "type": "url", "id": "social_instagram", "label": "Instagram" },
    { "type": "url", "id": "social_youtube", "label": "YouTube" },
    { "type": "url", "id": "social_tiktok", "label": "TikTok" },
    { "type": "url", "id": "social_twitter", "label": "X (Twitter)" }
  ],
  "presets": [{ "name": "MMW Stopka" }]
}
{% endschema %}
