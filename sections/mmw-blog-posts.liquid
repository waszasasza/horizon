{%- comment -%}
  mmw-blog-posts — "Nasze artykuły". Siatka wpisów z bloga + paginacja.
  Karta: zdjęcie (rounded 13) + data + tytuł + zajawka.
{%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} .mmw-bp { display:flex; flex-direction:column; align-items:center; gap:35px; padding-block:40px; padding-inline: var(--page-margin, 40px); }
  #shopify-section-{{ section.id }} .mmw-bp__head { font-family: var(--mmw-font-label); font-weight:700; font-size:18px; letter-spacing: var(--mmw-label-tracking); text-transform:uppercase; color: var(--mmw-01); margin:0; }
  #shopify-section-{{ section.id }} .mmw-bp__grid { display:grid; grid-template-columns: repeat(3, 1fr); gap:50px 38px; width:100%; }
  #shopify-section-{{ section.id }} .mmw-bp__card { display:flex; flex-direction:column; gap:13px; text-decoration:none; }
  #shopify-section-{{ section.id }} .mmw-bp__img { width:100%; aspect-ratio: 355 / 429; border-radius:13px; overflow:hidden; }
  #shopify-section-{{ section.id }} .mmw-bp__img img, #shopify-section-{{ section.id }} .mmw-bp__img svg { width:100%; height:100%; object-fit:cover; display:block; }
  #shopify-section-{{ section.id }} .mmw-bp__date { font-family: var(--mmw-font-label); font-weight:700; font-size:18px; letter-spacing: var(--mmw-label-tracking); text-transform:uppercase; color: var(--mmw-01); margin:0; }
  #shopify-section-{{ section.id }} .mmw-bp__title { font-family: var(--mmw-font-display); font-weight:400; font-size:36px; line-height:1; color: var(--mmw-01); margin:0; }
  #shopify-section-{{ section.id }} .mmw-bp__excerpt { font-family: var(--mmw-font-text); font-size:18px; line-height:1.4; color: var(--mmw-01); margin:0; }
  #shopify-section-{{ section.id }} .mmw-bp__btn { display:inline-flex; align-items:center; justify-content:center; background: var(--mmw-03); color: var(--mmw-01); font-family: var(--mmw-font-label); font-weight:700; font-size:13px; letter-spacing:1.95px; text-transform:uppercase; padding:20px 45px; border-radius:30px; text-decoration:none; }
  @media (max-width:989px){ #shopify-section-{{ section.id }} .mmw-bp__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width:649px){ #shopify-section-{{ section.id }} .mmw-bp__grid { grid-template-columns: 1fr; } }
{%- endstyle -%}
<section class="mmw-bp">
  {%- if section.settings.heading != blank -%}<p class="mmw-bp__head">{{ section.settings.heading }}</p>{%- endif -%}
  {%- paginate blog.articles by section.settings.per_page -%}
    <div class="mmw-bp__grid">
      {%- for post in blog.articles -%}
        <a class="mmw-bp__card" href="{{ post.url }}">
          <div class="mmw-bp__img">{%- if post.image -%}<img src="{{ post.image | image_url: width: 720 }}" alt="{{ post.title | escape }}" loading="lazy">{%- else -%}{{ 'image' | placeholder_svg_tag }}{%- endif -%}</div>
          <p class="mmw-bp__date">{{ post.published_at | date: '%d/%m/%Y' }}</p>
          <p class="mmw-bp__title">{{ post.title }}</p>
          <p class="mmw-bp__excerpt">{{ post.excerpt_or_content | strip_html | truncatewords: 14 }}</p>
        </a>
      {%- endfor -%}
    </div>
    {%- if paginate.next -%}
      <a class="mmw-bp__btn" href="{{ paginate.next.url }}">{{ section.settings.button_label }}</a>
    {%- endif -%}
  {%- endpaginate -%}
</section>
{% schema %}
{
  "name": "MMW Blog wpisy",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Nagłówek", "default": "Nasze artykuły" },
    { "type": "range", "id": "per_page", "min": 3, "max": 12, "step": 3, "label": "Wpisów na stronę", "default": 6 },
    { "type": "text", "id": "button_label", "label": "Tekst przycisku", "default": "Załaduj więcej" }
  ],
  "presets": [{ "name": "MMW Blog wpisy" }]
}
{% endschema %}
