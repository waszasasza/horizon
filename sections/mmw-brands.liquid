{%- comment -%}
  mmw-brands — "Nasze marki". Każdy blok = marka: eyebrow + nazwa + opis + przycisk + zdjęcie.
  Układ naprzemienny (zdjęcie raz z prawej, raz z lewej). Tło i kolory ustawiane per blok.
{%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} .mmw-brand { display:flex; gap:120px; align-items:center; justify-content:center; padding-block:60px; padding-inline: max(var(--page-margin, 40px), calc((100% - var(--mmw-article-width, 1240px)) / 2)); }
  #shopify-section-{{ section.id }} .mmw-brand--rev { flex-direction:row-reverse; }
  #shopify-section-{{ section.id }} .mmw-brand__text { flex:1 1 50%; min-width:0; display:flex; align-items:center; }
  #shopify-section-{{ section.id }} .mmw-brand__inner { display:flex; flex-direction:column; gap:50px; align-items:flex-start; width:100%; max-width:457px; }
  #shopify-section-{{ section.id }} .mmw-brand__group { display:flex; flex-direction:column; gap:20px; }
  #shopify-section-{{ section.id }} .mmw-brand__eyebrow { font-family: var(--mmw-font-label); font-weight:700; font-size:18px; letter-spacing: var(--mmw-label-tracking); text-transform:uppercase; margin:0; }
  #shopify-section-{{ section.id }} .mmw-brand__name { font-family: var(--mmw-font-display); font-weight:400; font-size: clamp(40px,5vw,64px); line-height:1.1; margin:0; }
  #shopify-section-{{ section.id }} .mmw-brand__desc { font-family: var(--mmw-font-text); font-size:18px; line-height:1.5; margin:0; }
  #shopify-section-{{ section.id }} .mmw-brand__btn { display:inline-flex; align-items:center; justify-content:center; font-family: var(--mmw-font-label); font-weight:700; font-size:13px; letter-spacing:1.95px; text-transform:uppercase; padding:18px 60px; border-radius:50px; text-decoration:none; }
  #shopify-section-{{ section.id }} .mmw-brand__media { flex:1 1 50%; min-width:0; aspect-ratio: 524 / 645; border-radius:20px; overflow:hidden; }
  #shopify-section-{{ section.id }} .mmw-brand__media img, #shopify-section-{{ section.id }} .mmw-brand__media svg { width:100%; height:100%; object-fit:cover; display:block; }
  @media (max-width:989px){
    #shopify-section-{{ section.id }} .mmw-brand, #shopify-section-{{ section.id }} .mmw-brand--rev { flex-direction:column; gap:32px; padding-block:40px; }
    #shopify-section-{{ section.id }} .mmw-brand__text { max-width:100%; }
    #shopify-section-{{ section.id }} .mmw-brand__media { flex-basis:auto; max-width:100%; width:100%; }
  }
{%- endstyle -%}
{%- for block in section.blocks -%}
  {%- liquid
    assign is_odd = forloop.index0 | modulo: 2
    assign fg = block.settings.text_color
    assign bg = block.settings.bg_color
    assign btn_bg = block.settings.button_bg
    assign btn_fg = block.settings.button_color
  -%}
  <section class="mmw-brand {% if is_odd == 1 %}mmw-brand--rev{% endif %}" style="background: {{ bg }}; color: {{ fg }};" {{ block.shopify_attributes }}>
    <div class="mmw-brand__text">
      <div class="mmw-brand__inner">
        <div class="mmw-brand__group">
          {%- if block.settings.eyebrow != blank -%}<p class="mmw-brand__eyebrow">{{ block.settings.eyebrow }}</p>{%- endif -%}
          {%- if block.settings.name != blank -%}<p class="mmw-brand__name">{{ block.settings.name }}</p>{%- endif -%}
          {%- if block.settings.desc != blank -%}<p class="mmw-brand__desc">{{ block.settings.desc }}</p>{%- endif -%}
        </div>
        {%- if block.settings.button_label != blank -%}
          <a class="mmw-brand__btn" href="{{ block.settings.button_url | default: '/collections/all' }}" style="background: {{ btn_bg }}; color: {{ btn_fg }};">{{ block.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
    <div class="mmw-brand__media">{%- if block.settings.image -%}<img src="{{ block.settings.image | image_url: width: 1080 }}" alt="{{ block.settings.name | escape }}" loading="lazy">{%- else -%}{{ 'image' | placeholder_svg_tag }}{%- endif -%}</div>
  </section>
{%- endfor -%}
{% schema %}
{
  "name": "MMW Nasze marki",
  "tag": "section",
  "max_blocks": 12,
  "blocks": [
    {
      "type": "brand",
      "name": "Marka",
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Etykieta", "default": "Nasze marki" },
        { "type": "text", "id": "name", "label": "Nazwa marki", "default": "Spiżarnia Książęca" },
        { "type": "textarea", "id": "desc", "label": "Opis" },
        { "type": "image_picker", "id": "image", "label": "Zdjęcie" },
        { "type": "text", "id": "button_label", "label": "Tekst przycisku", "default": "Zobacz produkty" },
        { "type": "url", "id": "button_url", "label": "Link przycisku" },
        { "type": "header", "content": "Kolory" },
        { "type": "color", "id": "bg_color", "label": "Tło sekcji", "default": "#faf2e8" },
        { "type": "color", "id": "text_color", "label": "Kolor tekstu", "default": "#5f312f" },
        { "type": "color", "id": "button_bg", "label": "Tło przycisku", "default": "#5f312f" },
        { "type": "color", "id": "button_color", "label": "Tekst przycisku", "default": "#faf2e8" }
      ]
    }
  ],
  "presets": [{ "name": "MMW Nasze marki", "blocks": [ {"type":"brand"},{"type":"brand"},{"type":"brand"},{"type":"brand"},{"type":"brand"} ] }]
}
{% endschema %}
