{%- comment -%}
  mmw-hero — sekcja hero strony głównej (Majątek Mała Wieś)
  WZORZEC dla kolejnych sekcji mmw-:
    - kolory/fonty wyłącznie przez var(--mmw-*) z mmw-tokens
    - style scope'owane przez #shopify-section-{{ section.id }}
    - edytowalne ustawienia w schema + bloki + preset
{%- endcomment -%}

{%- style -%}
  #shopify-section-{{ section.id }} .mmw-hero {
    position: relative;
    min-height: {{ section.settings.height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
    overflow: hidden;
    background-color: var(--mmw-01);
  }
  #shopify-section-{{ section.id }} .mmw-hero__bg {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  #shopify-section-{{ section.id }} .mmw-hero__overlay {
    position: absolute; inset: 0; z-index: 1;
    background: rgba(0, 0, 0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});
  }
  #shopify-section-{{ section.id }} .mmw-hero__inner {
    position: relative; z-index: 2;
    display: flex; flex-direction: column; align-items: center;
    gap: 53px; text-align: center;
  }
  #shopify-section-{{ section.id }} .mmw-hero__logo { width: 270px; max-width: 70vw; height: auto; }
  #shopify-section-{{ section.id }} .mmw-hero__heading {
    margin: 0;
    font-family: var(--mmw-font-display);
    font-weight: 400;
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.1;
    color: var(--mmw-04);
    max-width: 600px;
  }
  #shopify-section-{{ section.id }} .mmw-hero__buttons {
    display: flex; flex-wrap: wrap; gap: 37px; justify-content: center;
  }
  #shopify-section-{{ section.id }} .mmw-btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 10px 48px;
    border-radius: 50px;
    font-family: var(--mmw-font-label);
    font-weight: 700;
    font-size: var(--mmw-button-size);
    letter-spacing: var(--mmw-label-tracking);
    text-transform: uppercase;
    text-decoration: none;
    transition: opacity .2s ease;
  }
  #shopify-section-{{ section.id }} .mmw-btn:hover { opacity: .85; }
  #shopify-section-{{ section.id }} .mmw-btn--dark   { background: var(--mmw-01); color: var(--mmw-02); }
  #shopify-section-{{ section.id }} .mmw-btn--light  { background: var(--mmw-04); color: var(--mmw-01); }
  #shopify-section-{{ section.id }} .mmw-btn--accent { background: var(--mmw-02); color: var(--mmw-04); }

  @media (max-width: 749px) {
    #shopify-section-{{ section.id }} .mmw-hero__heading {
      font-size: {{ section.settings.heading_size | times: 0.55 | round }}px;
    }
    #shopify-section-{{ section.id }} .mmw-hero__inner { gap: 32px; }
  }
{%- endstyle -%}

<section class="mmw-hero">
  {%- if section.settings.background_image -%}
    <img
      class="mmw-hero__bg"
      src="{{ section.settings.background_image | image_url: width: 2400 }}"
      srcset="{{ section.settings.background_image | image_url: width: 1200 }} 1200w,
              {{ section.settings.background_image | image_url: width: 2400 }} 2400w"
      sizes="100vw"
      alt=""
      loading="eager"
      width="{{ section.settings.background_image.width }}"
      height="{{ section.settings.background_image.height }}"
    >
  {%- endif -%}
  <div class="mmw-hero__overlay"></div>

  <div class="mmw-hero__inner">
    {%- if section.settings.logo -%}
      <img class="mmw-hero__logo"
           src="{{ section.settings.logo | image_url: width: 540 }}"
           alt="{{ shop.name | escape }}" width="270" height="auto" loading="eager">
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h1 class="mmw-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="mmw-hero__buttons">
        {%- for block in section.blocks -%}
          {%- if block.type == 'button' and block.settings.label != blank -%}
            <a href="{{ block.settings.link | default: '#' }}"
               class="mmw-btn mmw-btn--{{ block.settings.style }}"
               {{ block.shopify_attributes }}>
              {{ block.settings.label }}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "MMW Hero",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "background_image", "label": "Zdjęcie tła" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 80, "step": 5, "unit": "%", "label": "Przyciemnienie tła", "default": 30 },
    { "type": "image_picker", "id": "logo", "label": "Logo / sygnet (opcjonalnie)" },
    { "type": "text", "id": "heading", "label": "Nagłówek", "default": "Jabłko. Tradycja. Smak." },
    { "type": "range", "id": "heading_size", "min": 40, "max": 96, "step": 2, "unit": "px", "label": "Rozmiar nagłówka", "default": 80 },
    { "type": "range", "id": "height", "min": 400, "max": 1000, "step": 20, "unit": "px", "label": "Wysokość sekcji", "default": 820 }
  ],
  "blocks": [
    {
      "type": "button",
      "name": "Przycisk",
      "settings": [
        { "type": "text", "id": "label", "label": "Tekst", "default": "SKLEP" },
        { "type": "url", "id": "link", "label": "Link" },
        {
          "type": "select", "id": "style", "label": "Styl", "default": "dark",
          "options": [
            { "value": "dark",   "label": "Ciemny (brąz)" },
            { "value": "light",  "label": "Jasny (krem)" },
            { "value": "accent", "label": "Akcent (koral)" }
          ]
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "MMW Hero",
      "settings": { "heading": "Jabłko. Tradycja. Smak.", "overlay_opacity": 30, "heading_size": 80, "height": 820 },
      "blocks": [
        { "type": "button", "settings": { "label": "SKLEP", "style": "dark" } },
        { "type": "button", "settings": { "label": "BESTSELLERY", "style": "light" } }
      ]
    }
  ]
}
{% endschema %}
