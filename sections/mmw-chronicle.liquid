{%- comment -%}
  mmw-chronicle — „Z Kroniki…". Trzy zakładki I·II·III z metafields kolekcji:
    teksty:  custom.kronika_1 / _2 / _3 (rich text)
    obrazy:  custom.obraz_kroniki / _2 / _3 (file/image, jeden na zakładkę)
  Rich text renderuje się ze stylami sklepu (klasa .rte), bez własnych nadpisań typografii.
{%- endcomment -%}
{%- liquid
  assign k1 = collection.metafields.custom.kronika
  assign k2 = collection.metafields.custom.kronika_2
  assign k3 = collection.metafields.custom.kronika_3
  assign img1 = collection.metafields.custom.obraz_kroniki
  assign img2 = collection.metafields.custom.obraz_kroniki_2
  assign img3 = collection.metafields.custom.obraz_kroniki_3
-%}
{%- style -%}
  #shopify-section-{{ section.id }} .mmw-chr {
    background: var(--mmw-01); color: var(--mmw-04);
    padding: 60px; display: flex; justify-content: center;
  }
  #shopify-section-{{ section.id }} .mmw-chr__wrap { display: flex; flex-direction: column; gap: 41px; width: 100%; max-width: 1200px; }
  #shopify-section-{{ section.id }} .mmw-chr__row { display: flex; gap: 30px; align-items: stretch; }
  #shopify-section-{{ section.id }} .mmw-chr__left { display: flex; flex-direction: column; justify-content: space-between; gap: 40px; flex: 1 1 591px; min-width: 0; }
  #shopify-section-{{ section.id }} .mmw-chr__panel { display: none; }
  #shopify-section-{{ section.id }} .mmw-chr__panel.is-active { display: block; }
  /* rich text dziedziczy kolor sekcji, reszta stylów ze sklepu (.rte) */
  #shopify-section-{{ section.id }} .mmw-chr__panel .rte { color: var(--mmw-04); }
  #shopify-section-{{ section.id }} .mmw-chr__tabs { display: flex; gap: 17px; align-items: center; }
  #shopify-section-{{ section.id }} .mmw-chr__tab {
    background: none; border: none; cursor: pointer; padding: 0;
    font-family: var(--mmw-font-label); font-weight: 700; font-size: 18px;
    letter-spacing: var(--mmw-label-tracking); text-transform: uppercase; color: var(--mmw-04);
  }
  #shopify-section-{{ section.id }} .mmw-chr__tab.is-active { color: var(--mmw-02); }
  #shopify-section-{{ section.id }} .mmw-chr__dot { width: 5px; height: 5px; border-radius: 50%; background: var(--mmw-04); flex-shrink: 0; }
  #shopify-section-{{ section.id }} .mmw-chr__media { flex: 0 0 540px; border-radius: 8px; overflow: hidden; position: relative; }
  #shopify-section-{{ section.id }} .mmw-chr__img { display: none; width: 100%; height: 100%; }
  #shopify-section-{{ section.id }} .mmw-chr__img.is-active { display: block; }
  #shopify-section-{{ section.id }} .mmw-chr__media img, #shopify-section-{{ section.id }} .mmw-chr__media svg { width: 100%; height: 100%; object-fit: cover; display: block; }
  @media (max-width: 989px) {
    #shopify-section-{{ section.id }} .mmw-chr { padding: 40px 20px; }
    #shopify-section-{{ section.id }} .mmw-chr__row { flex-direction: column; }
    #shopify-section-{{ section.id }} .mmw-chr__left { flex: 0 0 auto; justify-content: flex-start; gap: 24px; }
    #shopify-section-{{ section.id }} .mmw-chr__media { flex-basis: auto; height: 300px; }
  }
{%- endstyle -%}
<section class="mmw-chr">
  <div class="mmw-chr__wrap">
    <div class="mmw-chr__row">
      <div class="mmw-chr__left">
        <div class="mmw-chr__panels">
          <div class="mmw-chr__panel is-active" data-panel="1"><div class="rte">{{ k1 | metafield_tag }}</div></div>
          <div class="mmw-chr__panel" data-panel="2"><div class="rte">{{ k2 | metafield_tag }}</div></div>
          <div class="mmw-chr__panel" data-panel="3"><div class="rte">{{ k3 | metafield_tag }}</div></div>
        </div>
        <div class="mmw-chr__tabs">
          <button type="button" class="mmw-chr__tab is-active" data-target="1">I</button>
          <span class="mmw-chr__dot"></span>
          <button type="button" class="mmw-chr__tab" data-target="2">II</button>
          <span class="mmw-chr__dot"></span>
          <button type="button" class="mmw-chr__tab" data-target="3">III</button>
        </div>
      </div>
      <div class="mmw-chr__media">
        {%- assign imgs = '' -%}
        <div class="mmw-chr__img is-active" data-img="1">
          {%- if img1 != blank -%}<img src="{{ img1 | image_url: width: 1080 }}" alt="{{ collection.title | escape }}" loading="lazy">{%- else -%}{{ 'image' | placeholder_svg_tag }}{%- endif -%}
        </div>
        <div class="mmw-chr__img" data-img="2">
          {%- if img2 != blank -%}<img src="{{ img2 | image_url: width: 1080 }}" alt="{{ collection.title | escape }}" loading="lazy">{%- else -%}{{ 'image' | placeholder_svg_tag }}{%- endif -%}
        </div>
        <div class="mmw-chr__img" data-img="3">
          {%- if img3 != blank -%}<img src="{{ img3 | image_url: width: 1080 }}" alt="{{ collection.title | escape }}" loading="lazy">{%- else -%}{{ 'image' | placeholder_svg_tag }}{%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>
<script>
  (function(){
    var s=document.getElementById('shopify-section-{{ section.id }}'); if(!s) return;
    s.querySelectorAll('.mmw-chr__tab').forEach(function(tab){
      tab.addEventListener('click',function(){
        var id=tab.getAttribute('data-target');
        s.querySelectorAll('.mmw-chr__tab').forEach(function(t){ t.classList.toggle('is-active',t===tab); });
        s.querySelectorAll('.mmw-chr__panel').forEach(function(p){ p.classList.toggle('is-active',p.getAttribute('data-panel')===id); });
        s.querySelectorAll('.mmw-chr__img').forEach(function(i){ i.classList.toggle('is-active',i.getAttribute('data-img')===id); });
      });
    });
  })();
</script>
{% schema %}
{
  "name": "MMW Kronika",
  "tag": "section",
  "settings": [
    { "type": "paragraph", "content": "Teksty: custom.kronika_1/2/3. Obrazy: custom.obraz_kroniki / _2 / _3. Wszystko per kolekcja przez metafields." }
  ],
  "presets": [{ "name": "MMW Kronika" }]
}
{% endschema %}
