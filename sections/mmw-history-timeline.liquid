{%- comment -%}
  mmw-history-timeline — "Nasza historia".
  Oś czasu z efektem PIN + poziomy scroll: scroll w dół przewija sekcję w bok,
  po dojściu do końca strona scrolluje się normalnie.
  - Desktop: sticky pinuje, JS przelicza translateX ze scrolla (bez porywania wheela).
  - Mobile / reduced-motion / brak JS: natywny swipe w bok, pasek ukryty.
  Bloki: "photo" (górny rząd zdjęć), "year" (rok + opis; niebieska linia + kropki).
{%- endcomment -%}
{%- style -%}
  #shopify-section-{{ section.id }} .mmw-tl { padding-block:50px; }
  #shopify-section-{{ section.id }} .mmw-tl__eyebrow { font-family: var(--mmw-font-label); font-weight:700; font-size:18px; letter-spacing: var(--mmw-label-tracking); text-transform:uppercase; color: var(--mmw-01); text-align:center; margin:0 0 30px; padding-inline: var(--page-margin, 40px); }

  /* widok przewijany (natywny scroll, gdy brak pinu) */
  #shopify-section-{{ section.id }} .mmw-tl__viewport { overflow-x:auto; overflow-y:hidden; scrollbar-width:none; -ms-overflow-style:none; -webkit-overflow-scrolling:touch; }
  #shopify-section-{{ section.id }} .mmw-tl__viewport::-webkit-scrollbar { display:none; width:0; height:0; }

  /* tor poziomy: rząd zdjęć + rząd lat, ten sam offset */
  #shopify-section-{{ section.id }} .mmw-tl__track { display:flex; flex-direction:column; gap:30px; width:max-content; padding-inline: var(--page-margin, 40px); will-change:transform; }
  #shopify-section-{{ section.id }} .mmw-tl__row { display:flex; gap:60px; }
  #shopify-section-{{ section.id }} .mmw-tl__photo { flex:0 0 410px; height:420px; border-radius:20px; overflow:hidden; }
  #shopify-section-{{ section.id }} .mmw-tl__photo img, #shopify-section-{{ section.id }} .mmw-tl__photo svg { width:100%; height:100%; object-fit:cover; display:block; }

  /* rząd lat: niebieska linia + kropki */
  #shopify-section-{{ section.id }} .mmw-tl__years { position:relative; }
  #shopify-section-{{ section.id }} .mmw-tl__years::before { content:""; position:absolute; left:0; right:0; top:7px; height:2px; background: var(--mmw-tl-line, #C6D4E2); }
  #shopify-section-{{ section.id }} .mmw-tl__year { flex:0 0 410px; display:flex; flex-direction:column; gap:8px; color: var(--mmw-01); padding-top:34px; position:relative; }
  #shopify-section-{{ section.id }} .mmw-tl__year::before { content:""; position:absolute; left:0; top:0; width:16px; height:16px; border-radius:50%; background: var(--mmw-tl-line, #C6D4E2); }
  #shopify-section-{{ section.id }} .mmw-tl__year-num { font-family: var(--mmw-font-display); font-weight:400; font-size:64px; line-height:1.1; margin:0; }
  #shopify-section-{{ section.id }} .mmw-tl__year-text { font-family: var(--mmw-font-text); font-size:18px; line-height:1.5; margin:0; }

  /* stan PIN (włącza JS na desktopie) */
  #shopify-section-{{ section.id }} .mmw-tl.is-pinned .mmw-tl__sticky { position:sticky; top:0; height:100vh; display:flex; flex-direction:column; justify-content:center; gap:30px; overflow:hidden; }
  #shopify-section-{{ section.id }} .mmw-tl.is-pinned .mmw-tl__viewport { overflow:visible; }

  @media (max-width:749px){ #shopify-section-{{ section.id }} .mmw-tl__row { gap:24px; } #shopify-section-{{ section.id }} .mmw-tl__photo, #shopify-section-{{ section.id }} .mmw-tl__year { flex-basis:300px; } }
{%- endstyle -%}
<section class="mmw-tl" data-tl>
  {%- if section.settings.eyebrow != blank -%}<p class="mmw-tl__eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
  <div class="mmw-tl__pin">
    <div class="mmw-tl__sticky">
      <div class="mmw-tl__viewport">
        <div class="mmw-tl__track">
          {%- assign photos = section.blocks | where: 'type', 'photo' -%}
          {%- if photos.size > 0 -%}
            <div class="mmw-tl__row mmw-tl__photos">
              {%- for block in photos -%}
                <div class="mmw-tl__photo" {{ block.shopify_attributes }}>{%- if block.settings.image -%}<img src="{{ block.settings.image | image_url: width: 900 }}" alt="" loading="lazy">{%- else -%}{{ 'image' | placeholder_svg_tag }}{%- endif -%}</div>
              {%- endfor -%}
            </div>
          {%- endif -%}
          {%- assign years = section.blocks | where: 'type', 'year' -%}
          {%- if years.size > 0 -%}
            <div class="mmw-tl__row mmw-tl__years">
              {%- for block in years -%}
                <div class="mmw-tl__year" {{ block.shopify_attributes }}>
                  <p class="mmw-tl__year-num">{{ block.settings.year }}</p>
                  <p class="mmw-tl__year-text">{{ block.settings.text }}</p>
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>
<script>
  (function(){
    var root = document.getElementById('shopify-section-{{ section.id }}');
    if(!root) return;
    var sec = root.querySelector('[data-tl]');
    var pin = root.querySelector('.mmw-tl__pin');
    var vp  = root.querySelector('.mmw-tl__viewport');
    var track = root.querySelector('.mmw-tl__track');
    if(!sec||!pin||!vp||!track) return;

    var distance = 0, ticking = false;
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)');

    function canPin(){ return window.innerWidth > 749 && !reduce.matches; }

    function setup(){
      // reset
      sec.classList.remove('is-pinned');
      pin.style.height = '';
      track.style.transform = '';
      distance = 0;
      if(!canPin()) return;                  // mobile/reduced → natywny swipe
      var d = track.scrollWidth - vp.clientWidth;
      if(d <= 0) return;                      // mieści się → bez pinu
      distance = d;
      sec.classList.add('is-pinned');
      pin.style.height = (distance + window.innerHeight) + 'px';
      onScroll();
    }

    function onScroll(){
      if(!distance) return;
      var top = pin.getBoundingClientRect().top;
      var max = pin.offsetHeight - window.innerHeight;
      var p = Math.min(Math.max(-top / max, 0), 1);
      track.style.transform = 'translateX(' + (-p * distance) + 'px)';
    }

    function onScrollRAF(){
      if(ticking) return; ticking = true;
      requestAnimationFrame(function(){ onScroll(); ticking = false; });
    }

    window.addEventListener('scroll', onScrollRAF, { passive:true });
    window.addEventListener('resize', setup);
    if(reduce.addEventListener) reduce.addEventListener('change', setup);
    setup();
  })();
</script>
{% schema %}
{
  "name": "MMW Historia oś",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Etykieta", "default": "Nasza historia" }
  ],
  "blocks": [
    { "type": "photo", "name": "Zdjęcie (górny rząd)", "settings": [ { "type": "image_picker", "id": "image", "label": "Zdjęcie" } ] },
    { "type": "year", "name": "Rok (oś czasu)", "settings": [
        { "type": "text", "id": "year", "label": "Rok", "default": "1989" },
        { "type": "textarea", "id": "text", "label": "Opis" }
    ] }
  ],
  "presets": [{ "name": "MMW Historia oś", "blocks": [ {"type":"photo"},{"type":"photo"},{"type":"photo"},{"type":"photo"},{"type":"year"},{"type":"year"},{"type":"year"},{"type":"year"} ] }]
}
{% endschema %}
